{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Transparent Notes",
  "version": "1.0.0",
  "identifier": "com.danhi.ai-transparent-notes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Transparent Notes",
        "width": 960,
        "height": 640,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "center": true,
        "dragDropEnabled": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://api.anthropic.com https://api.openai.com https://api.deepseek.com; font-src 'self' data:; media-src 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Daniel Hinojosa",
    "copyright": "Copyright 2025 Daniel Hinojosa",
    "category": "Productivity",
    "shortDescription": "AI-powered notes app with multi-pane editing",
    "longDescription": "AI Transparent Notes is a modern cross-platform notes app with multi-pane editing, folder workspace browsing, and built-in AI assistance via Claude and OpenAI.",
    "homepage": "https://github.com/danhino/ai-transparent-notes",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "tsp": false,
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"]
      }
    }
  }
}
